# AquaLink sensor-only test variant — read the connected sensor and log it.
# No Matter, no BLE, no networking. For verifying probe wiring / the sensor.
#
#   launch-aqualink-wsl.cmd --sensor-only --rebuild
#
# build.sh passes -DAQUALINK_NO_MATTER=1 so the root CMakeLists skips the whole
# esp-matter stack (otherwise its NetworkCommissioning static_assert fails when
# no Thread/Wi-Fi transport is enabled).

CONFIG_AQUALINK_SENSOR_TEST=y

# Strip every radio stack — this is a bare sensor read.
CONFIG_OPENTHREAD_ENABLED=n
CONFIG_OPENTHREAD_MTD=n
CONFIG_ENABLE_WIFI_STATION=n
CONFIG_ENABLE_CHIPOBLE=n
CONFIG_BT_ENABLED=n
CONFIG_BT_NIMBLE_ENABLED=n
