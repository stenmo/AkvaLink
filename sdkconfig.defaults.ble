# AkvaLink BLE-only variant — standalone NimBLE GATT server, no Matter.
#
# Layer on top of the base defaults:
#   idf.py -DSDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.ble" reconfigure
# or via the launcher:  launch-akvalink-wsl.cmd --ble --rebuild
#
# For homes with no Matter hub and no Wi-Fi: a phone/app connects directly over
# BLE and reads device info + live temperature. See main/ble_gatt.cpp.

# Select the BLE-only app path (main/Kconfig.projbuild).
CONFIG_AKVALINK_BLE_ONLY=y

# No Matter network stacks — BLE only.
CONFIG_OPENTHREAD_ENABLED=n
CONFIG_OPENTHREAD_MTD=n
CONFIG_OPENTHREAD_SRP_CLIENT=n
CONFIG_OPENTHREAD_DNS_CLIENT=n
CONFIG_OPENTHREAD_JOINER=n
CONFIG_ENABLE_WIFI_STATION=n

# We own the NimBLE host directly (not via Matter's CHIPoBLE commissioning).
CONFIG_ENABLE_CHIPOBLE=n

# Keep BLE / NimBLE enabled.
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y

# --- BLE light sleep (DISABLED — validate with PPK2 before enabling) --------
# Set CONFIG_AKVALINK_BLE_PM=y in this file AND uncomment the three lines
# below once the measurement wiring is solid and the numbers look right.
# All three are required together — the IDF BLE controller hard-errors
# at compile time if BT_LE_SLEEP_ENABLE=y without MAC_BB_PD=y, and
# BT_LE_LP_CLK_SRC_DEFAULT is needed so the radio runs off the RTC slow
# clock (not the main XTAL, which is powered down in light sleep).
#
# CONFIG_AKVALINK_BLE_PM=y
# CONFIG_BT_LE_SLEEP_ENABLE=y
# CONFIG_BT_LE_LP_CLK_SRC_DEFAULT=y
# CONFIG_MAC_BB_PD=y

# Max ATT MTU — bigger GATT writes mean fewer round-trips, so faster BLE OTA.
# Chrome / modern phones negotiate up to 517; the peripheral advertises this and
# the link settles on min(peer, 517). Pairs with 2M PHY (set on connect in
# ble_gatt.cpp) for the best firmware-update throughput.
CONFIG_BT_NIMBLE_ATT_PREFERRED_MTU=517

# Extended advertising — REQUIRED for Coded PHY (long range). The GATT server
# rotates two advertising instances: legacy 1M (phone-friendly) + Coded S=8
# (long range). Needs at least 2 instances.
CONFIG_BT_NIMBLE_EXT_ADV=y
CONFIG_BT_NIMBLE_MAX_EXT_ADV_INSTANCES=1

# NOTE: esp-matter is NOT compiled into this variant — build.sh sets
# AKVALINK_NO_MATTER, so the root CMakeLists builds a plain ESP-IDF project
# (no esp_matter/chip/openthread requires). Only NimBLE + the sensor link in.
