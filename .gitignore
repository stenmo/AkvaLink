web/firmware/

# Serial monitor logs
logs/

# Prebuilt drop folder — keep the README, ignore the binaries.
images/*
!images/README.md

# Editor / OS cruft
.DS_Store
Thumbs.db
*.swp
*~

# ESPHome — real secrets stay local; placeholder committed for CI reference
esphome/secrets.yaml
.esphome/

# Python / pytest cruft
