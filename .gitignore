# Local build & venv outputs (do NOT commit).
build/
build.log
build_*.log
release_*.log
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock

# Release artifacts (merged images live here; regenerated by scripts/publish.py)
dist/

